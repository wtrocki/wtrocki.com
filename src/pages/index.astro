---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Home">
  <section style="max-width: 80rem; margin: 0 auto; padding: 5rem 2rem 3rem;">
    <div style="display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap;">
      <div style="flex: 1; min-width: 280px;">
        <p style="font-size: 0.875rem; color: #818cf8; font-weight: 500; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.75rem;">API Platforms &bull; Developer Tools &bull; AI</p>
        <h1 style="font-size: clamp(2.25rem, 5vw, 3.5rem); font-weight: 700; line-height: 1.1; letter-spacing: -0.03em; margin-bottom: 1rem; color: #f1f5f9;">
          Wojciech Trocki
        </h1>
        <p style="font-size: 1.125rem; color: #94a3b8; max-width: 36rem; line-height: 1.7; margin-bottom: 1.5rem;">
          Product Engineer focused on AI, APIs, and middleware. Principal Engineer at <strong style="color: #34d399;">MongoDB</strong> building identity, traffic shaping, and API governance at scale. Previously led mobile backend teams at Red Hat. OpenAPI &amp; GraphQL spec expert, AsyncAPI contributor, and builder of AI-augmented developer tooling.
        </p>
        <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
          <a href="https://github.com/wtrocki" style="display: inline-flex; align-items: center; gap: 0.375rem; padding: 0.5rem 1.25rem; border: 1px solid #334155; border-radius: 9999px; font-size: 0.875rem; font-weight: 500; color: #cbd5e1; text-decoration: none; transition: background 0.15s, border-color 0.15s; background: rgba(30, 41, 59, 0.6); backdrop-filter: blur(4px);">
            <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.385-1.335-1.755-1.335-1.755-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 21.795 24 17.295 24 12 24 5.37 18.63 0 12 0z"/></svg>
            GitHub
          </a>
          <a href="https://linkedin.com/in/wojciech-t-39574526" style="display: inline-flex; align-items: center; gap: 0.375rem; padding: 0.5rem 1.25rem; border: 1px solid #334155; border-radius: 9999px; font-size: 0.875rem; font-weight: 500; color: #cbd5e1; text-decoration: none; transition: background 0.15s, border-color 0.15s; background: rgba(30, 41, 59, 0.6); backdrop-filter: blur(4px);">
            <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            LinkedIn
          </a>
          <a href="https://twitter.com/typeapi" style="display: inline-flex; align-items: center; gap: 0.375rem; padding: 0.5rem 1.25rem; border: 1px solid #334155; border-radius: 9999px; font-size: 0.875rem; font-weight: 500; color: #cbd5e1; text-decoration: none; transition: background 0.15s, border-color 0.15s; background: rgba(30, 41, 59, 0.6); backdrop-filter: blur(4px);">
            <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            X
          </a>
          <a href="https://medium.com/@wtr" style="padding: 0.5rem 1.25rem; border: 1px solid #334155; border-radius: 9999px; font-size: 0.875rem; font-weight: 500; color: #cbd5e1; text-decoration: none; transition: background 0.15s, border-color 0.15s; background: rgba(30, 41, 59, 0.6); backdrop-filter: blur(4px);">Medium</a>
          <a href="mailto:wojciech@wtrocki.com" style="padding: 0.5rem 1.25rem; border: 1px solid #334155; border-radius: 9999px; font-size: 0.875rem; font-weight: 500; color: #cbd5e1; text-decoration: none; transition: background 0.15s, border-color 0.15s; background: rgba(30, 41, 59, 0.6); backdrop-filter: blur(4px);">Email</a>
          <a href="https://leaddev.com/community/wojtek-trocki" style="padding: 0.5rem 1.25rem; border: 1px solid #334155; border-radius: 9999px; font-size: 0.875rem; font-weight: 500; color: #cbd5e1; text-decoration: none; transition: background 0.15s, border-color 0.15s; background: rgba(30, 41, 59, 0.6); backdrop-filter: blur(4px);">LeadDev</a>
          <a href="https://patents.google.com/?q=(Wojciech)&amp;inventor=Trocki&amp;oq=Wojciech+Trocki" style="padding: 0.5rem 1.25rem; border: 1px solid #334155; border-radius: 9999px; font-size: 0.875rem; font-weight: 500; color: #cbd5e1; text-decoration: none; transition: background 0.15s, border-color 0.15s; background: rgba(30, 41, 59, 0.6); backdrop-filter: blur(4px);">Patents</a>
        </div>
      </div>
      <div style="flex-shrink: 0;">
        <img src="/assets/profile.png" alt="Wojciech Trocki" style="width: 260px; height: 260px; border-radius: 50%; object-fit: cover; border: 3px solid #334155;" />
      </div>
    </div>
  </section>

  <section style="max-width: 80rem; margin: 0 auto; padding: 4rem 2rem;">
    <h2 style="font-size: 1.5rem; font-weight: 600; margin-bottom: 2rem; letter-spacing: -0.02em; color: #f1f5f9;">What I Do</h2>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1.5rem;">
      <div style="position: relative; overflow: hidden; border-radius: 0.75rem; border: 1px solid #064e3b; background: linear-gradient(135deg, rgba(6, 78, 59, 0.3) 0%, rgba(30, 41, 59, 0.6) 50%, rgba(15, 23, 42, 0.8) 100%); backdrop-filter: blur(8px); padding: 1.75rem;">
        <div style="position: absolute; top: -30px; right: -20px; width: 100px; height: 100px; border-radius: 50%; background: rgba(52, 211, 153, 0.08); pointer-events: none;"></div>
        <div style="display: inline-flex; align-items: center; justify-content: center; width: 2.75rem; height: 2.75rem; border-radius: 0.625rem; background: rgba(52, 211, 153, 0.15); margin-bottom: 1rem;">
          <svg width="20" height="20" fill="none" stroke="#34d399" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M12 2a4 4 0 0 1 4 4v1h3a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V9a2 2 0 0 1 2-2h3V6a4 4 0 0 1 4-4z"/><circle cx="10" cy="14" r="1.5"/><circle cx="14" cy="14" r="1.5"/><path d="M9 18c.83.67 1.83 1 3 1s2.17-.33 3-1"/></svg>
        </div>
        <h3 style="font-weight: 600; font-size: 1.0625rem; margin-bottom: 0.5rem; color: #6ee7b7;">AI &amp; Agent Tooling</h3>
        <p style="font-size: 0.9375rem; color: #94a3b8; line-height: 1.6;">Building MCP servers, code generation pipelines, and AI-assisted developer workflows that turn natural language into running code. Active speaker at industry events.</p>
      </div>
      <div style="position: relative; overflow: hidden; border-radius: 0.75rem; border: 1px solid #312e81; background: linear-gradient(135deg, rgba(49, 46, 129, 0.3) 0%, rgba(30, 41, 59, 0.6) 50%, rgba(15, 23, 42, 0.8) 100%); backdrop-filter: blur(8px); padding: 1.75rem;">
        <div style="position: absolute; top: -30px; right: -20px; width: 100px; height: 100px; border-radius: 50%; background: rgba(99, 102, 241, 0.08); pointer-events: none;"></div>
        <div style="display: inline-flex; align-items: center; justify-content: center; width: 2.75rem; height: 2.75rem; border-radius: 0.625rem; background: rgba(99, 102, 241, 0.15); margin-bottom: 1rem;">
          <svg width="20" height="20" fill="none" stroke="#818cf8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/></svg>
        </div>
        <h3 style="font-weight: 600; font-size: 1.0625rem; margin-bottom: 0.5rem; color: #c7d2fe;">API Platforms</h3>
        <p style="font-size: 0.9375rem; color: #94a3b8; line-height: 1.6;">Designing and building next-generation API infrastructure — GraphQL, REST, OpenAPI. Authentication, traffic shaping, and API governance at scale.</p>
      </div>
      <div style="position: relative; overflow: hidden; border-radius: 0.75rem; border: 1px solid #831843; background: linear-gradient(135deg, rgba(131, 24, 67, 0.3) 0%, rgba(30, 41, 59, 0.6) 50%, rgba(15, 23, 42, 0.8) 100%); backdrop-filter: blur(8px); padding: 1.75rem;">
        <div style="position: absolute; top: -30px; right: -20px; width: 100px; height: 100px; border-radius: 50%; background: rgba(244, 114, 182, 0.08); pointer-events: none;"></div>
        <div style="display: inline-flex; align-items: center; justify-content: center; width: 2.75rem; height: 2.75rem; border-radius: 0.625rem; background: rgba(244, 114, 182, 0.15); margin-bottom: 1rem;">
          <svg width="20" height="20" fill="none" stroke="#f472b6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
        </div>
        <h3 style="font-weight: 600; font-size: 1.0625rem; margin-bottom: 0.5rem; color: #f9a8d4;">API Standards</h3>
        <p style="font-size: 0.9375rem; color: #94a3b8; line-height: 1.6;">Spec-first API design with OpenAPI and GraphQL. Schema governance, automated linting, design reviews, and API governance at scale. AsyncAPI contributor.</p>
      </div>
      <div style="position: relative; overflow: hidden; border-radius: 0.75rem; border: 1px solid #78350f; background: linear-gradient(135deg, rgba(120, 53, 15, 0.3) 0%, rgba(30, 41, 59, 0.6) 50%, rgba(15, 23, 42, 0.8) 100%); backdrop-filter: blur(8px); padding: 1.75rem;">
        <div style="position: absolute; top: -30px; right: -20px; width: 100px; height: 100px; border-radius: 50%; background: rgba(245, 158, 11, 0.08); pointer-events: none;"></div>
        <div style="display: inline-flex; align-items: center; justify-content: center; width: 2.75rem; height: 2.75rem; border-radius: 0.625rem; background: rgba(245, 158, 11, 0.15); margin-bottom: 1rem;">
          <svg width="20" height="20" fill="none" stroke="#fbbf24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><polyline points="16 3 21 3 21 8"/><line x1="4" y1="20" x2="21" y2="3"/><polyline points="21 16 21 21 16 21"/><line x1="15" y1="15" x2="21" y2="21"/><line x1="4" y1="4" x2="9" y2="9"/></svg>
        </div>
        <h3 style="font-weight: 600; font-size: 1.0625rem; margin-bottom: 0.5rem; color: #fcd34d;">Developer Tools</h3>
        <p style="font-size: 0.9375rem; color: #94a3b8; line-height: 1.6;">Open-source tools, CLI applications, SDKs, and frameworks. AsyncAPI contributor. Cloud-native infrastructure with Go, Node.js, and Java.</p>
      </div>
    </div>
  </section>

  <section style="max-width: 80rem; margin: 0 auto; padding: 4rem 2rem 2rem;">
    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 2rem;">
      <h2 style="font-size: 1.5rem; font-weight: 600; letter-spacing: -0.02em; color: #f1f5f9;">Recent Writing</h2>
      <div style="display: flex; align-items: center; gap: 1rem;">
        <a href="/rss.xml" title="RSS Feed" style="display: inline-flex; align-items: center; color: #f59e0b; transition: color 0.15s;">
          <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20 5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93v-2.83z"/></svg>
        </a>
        <a href="/blog" style="font-size: 0.9375rem; font-weight: 500; color: #818cf8; text-decoration: none;">View all &rarr;</a>
      </div>
    </div>
    <div style="display: flex; flex-direction: column; gap: 1rem;">
      {posts.map((post) => (
        <a href={`/blog/${post.id}`} style="display: flex; align-items: center; justify-content: space-between; padding: 1rem 1.5rem; border: 1px solid #1e293b; border-radius: 0.75rem; background: rgba(30, 41, 59, 0.4); backdrop-filter: blur(8px); text-decoration: none; transition: border-color 0.15s, background 0.15s;">
          <span style="font-weight: 500; color: #e2e8f0;">{post.data.title}</span>
          <span style="font-size: 0.875rem; color: #64748b; flex-shrink: 0; margin-left: 1rem;">
            {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long' })}
          </span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
