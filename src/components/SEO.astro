---
export interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  slug?: string;
  date?: Date;
  tags?: string[];
}

const {
  title,
  description = 'Personal site of Wojciech Trocki — API platforms, developer tools, AI, and open source.',
  image = '/assets/profile.png',
  type = 'website',
  slug,
  date,
  tags = [],
} = Astro.props;

const siteUrl = Astro.site.toString().replace(/\/$/, '');
const pageUrl = slug ? `${siteUrl}/blog/${slug}` : siteUrl;
const pageImage = image.startsWith('http') ? image : `${siteUrl}/${image.replace(/^\//, '')}`;
---

<meta property="og:title" content={`${title} — Wojciech Trocki`} />
<meta property="og:description" content={description} />
<meta property="og:image" content={pageImage} />
<meta property="og:url" content={pageUrl} />
<meta property="og:type" content={type} />
<meta property="og:site_name" content="Wojciech Trocki" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={`${title} — Wojciech Trocki`} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={pageImage} />

<link rel="canonical" href={pageUrl} />

{
  type === 'article' && date && (
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'BlogPosting',
      headline: title,
      description,
      image: pageImage,
      url: pageUrl,
      datePublished: date.toISOString(),
      author: {
        '@type': 'Person',
        name: 'Wojciech Trocki',
        url: siteUrl,
      },
      keywords: tags.join(', '),
    })} />
  )
}
