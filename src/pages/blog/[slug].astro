---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogPost from '../../layouts/BlogPost.astro';
import SEO from '../../components/SEO.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props as { post: CollectionEntry<'blog'> };
const showContent = (post.rendered?.html ?? '').trim().length > 0;
---

{
  showContent ? (
    <BlogPost
      title={post.data.title}
      date={post.data.date}
      description={post.data.description}
      tags={post.data.tags}
      image={post.data.image}
      slug={post.id}
    >
      <div set:html={post.rendered?.html ?? ''} />
    </BlogPost>
  ) : (
    <BaseLayout title={post.data.title} description={post.data.description}>
      <SEO
        title={post.data.title}
        description={post.data.description ?? 'Blog post by Wojciech Trocki.'}
        image={post.data.image}
        type="article"
        slug={post.id}
        date={post.data.date}
        tags={post.data.tags}
        slot="head"
      />
      <article style="max-width: 48rem; margin: 0 auto; padding: 3rem 2rem 6rem;">
        <time style="font-size: 0.875rem; color: #94a3b8; display: block; margin-bottom: 0.75rem;">
          {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <h1 style="font-size: 2rem; font-weight: 700; line-height: 1.2; letter-spacing: -0.02em; margin-bottom: 1.5rem; color: #f1f5f9;">{post.data.title}</h1>
        {
          (post.data.tags ?? []).length > 0 && (
            <div style="display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 2rem;">
              {(post.data.tags ?? []).map((tag: string) => (
                <span style="display: inline-block; padding: 0.25rem 0.75rem; border: 1px solid #e5e7eb; border-radius: 9999px; font-size: 0.8125rem; color: #6b7280; background: #f9fafb;">
                  #{tag}
                </span>
              ))}
            </div>
          )
        }
        <p style="font-size: 1.125rem; color: #666; line-height: 1.7;">Coming soon.</p>
        {post.data.externalUrl && (
          <p style="margin-top: 2rem;">
            <a href={post.data.externalUrl} style="display: inline-block; padding: 0.625rem 1.5rem; background: #34d399; color: #0a0e24; font-weight: 600; font-size: 0.9375rem; border-radius: 9999px; text-decoration: none;">
              Read on {new URL(post.data.externalUrl).hostname.replace('www.', '')} &rarr;
            </a>
          </p>
        )}
      </article>
    </BaseLayout>
  )
}
