---
import SEO from '../components/SEO.astro';
export interface Props {
  title: string;
  description?: string;
  image?: string;
}
const { title, description, image } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Wojciech Trocki</title>
    <meta name="description" content={description ?? "Personal site of Wojciech Trocki — API platforms, developer tools, AI, and open source."} />
    <SEO title={title} description={description} image={image} slot="head" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/png" href="/favicon-32x32.png" />
    <link rel="alternate" type="application/rss+xml" title="Wojciech Trocki — Engineering Blog" href="/rss.xml" />
    <slot name="head" />
  </head>
  <body style="margin: 0; font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #0a0e24; color: #f1f5f9; -webkit-font-smoothing: antialiased;">
    <bb-ambient-ribbon
      style="position: fixed; inset: 0; z-index: 0; pointer-events: none;"
      ribbon-count="4"
      ribbon-width="80"
      ribbon-rotation="30"
      bg-colors="#0a0e24,#0a0e24"
      ribbon-hue-start="225"
      ribbon-hue-end="235"
      ribbon-saturation-start="25"
      ribbon-saturation-end="35"
      ribbon-lightness-start="12"
      ribbon-lightness-end="18"
      ribbon-line-width="1.5"
      ribbon-line-opacity="0.12"
      ribbon-amplitude="0.4"
    ></bb-ambient-ribbon>

    <div style="position: relative; z-index: 1; min-height: 100vh; display: flex; flex-direction: column;">
      <nav style="max-width: 80rem; margin: 0 auto; padding: 1.5rem 2rem; display: flex; align-items: center; justify-content: space-between; width: 100%;">
        <div style="display: flex; gap: 2rem; font-size: 0.9375rem;">
          <a href="/" style="color: #94a3b8; text-decoration: none; transition: color 0.15s;">Home</a>
          <a href="/about" style="color: #94a3b8; text-decoration: none; transition: color 0.15s;">About</a>
          <a href="/blog" style="color: #94a3b8; text-decoration: none; transition: color 0.15s;">Blog</a>
          <a href="/tags" style="color: #94a3b8; text-decoration: none; transition: color 0.15s;">Tags</a>
        </div>
      </nav>

      <main style="flex: 1;">
        <slot />
      </main>

      <footer style="max-width: 80rem; margin: 0 auto; padding: 2rem 2rem 3rem; text-align: center; font-size: 0.875rem; color: #475569; border-top: 1px solid #1e293b; width: 100%;">
        <p>&copy; {new Date().getFullYear()} Wojciech Trocki</p>
      </footer>
    </div>

    <script>
      import 'beautiful-backgrounds';
    </script>

<style>
  /* Lighten all muted text colors across the site */
  [style*="color: #94a3b8"] { color: #cbd5e1 !important; }
  [style*="color: #64748b"] { color: #cbd5e1 !important; }
  [style*="color: #666"] { color: #cbd5e1 !important; }
  [style*="color: #888"] { color: #94a3b8 !important; }
  [style*="color: #6b7280"] { color: #cbd5e1 !important; }
  [style*="color: #475569"] { color: #94a3b8 !important; }
  [style*="color: #9ca3af"] { color: #cbd5e1 !important; }
  
</style>
  </body>
</html>
